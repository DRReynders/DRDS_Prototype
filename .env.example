# Copy this file to `.env` (same folder) and fill in the real values.
# `.env` is gitignored and must never be committed.

# Which LLM provider the pipeline uses. Supported values:
#   anthropic  (default) — real reasoning; requires ANTHROPIC_API_KEY below
#   mock                  — structural testing only; every output is marked [MOCK],
#                           zero tokens / zero cost. Explicit opt-in only.
DRDS_LLM_PROVIDER=anthropic

# Required when DRDS_LLM_PROVIDER=anthropic. Add your real key locally before
# running the full pipeline (Contracts 1, 2, 4 and 5 make real LLM calls).
ANTHROPIC_API_KEY=

# --- Task-level model routing (configuration, never hardcoded in Contracts) ---
# "fast" tier — simple extraction/classification (CIP identification, evidence
# text checks). Default: claude-haiku-4-5-20251001
DRDS_MODEL_FAST=
# "reasoning" tier — Goal Model inference, CDER reasoning, Snapshot copywriting.
# Default: claude-sonnet-5
DRDS_MODEL_REASONING=
# Optional single override: if set, BOTH tiers use this model (wins over the two above).
DRDS_MODEL=

# --- Budget guards (soft limits) ---
# Maximum estimated spend per run, in USD. Checked before each LLM call; when
# reached, the run stops gracefully with a clear message. Empty or 0 = no limit.
# A typical full run makes 4-8 calls; 0.50 is a generous first ceiling.
MAX_RUN_COST_USD=0.50
# Maximum estimated spend per calendar day across all runs (public protection).
# When reached, new visitors see an honest "at capacity today" message.
MAX_DAILY_COST_USD=5.00

# --- Public exposure guards ---
# Growth Snapshot runs allowed per IP per hour. 0 disables the limit.
RATE_LIMIT_RUNS_PER_HOUR=4

# --- Transactional email (Resend) ---
# Required for the follow-up email. Without it, the Snapshot still displays and
# the email form reports honestly that sending is not configured.
RESEND_API_KEY=
# Verified sender. The domain must be verified in Resend (DNS records) first.
EMAIL_FROM=DRDS Growth Snapshot <snapshot@drdigitalsystems.co.za>

# --- Web server ---
PORT=3000
